set -euo

ssh="/home/tikal-root/.ssh"
$log --tag=ssh "Adding the key $private/id_ed25519 to $ssh"

if [[ ! -d "$ssh" ]]; then
  mkdir -p "$ssh"
  chmod 0700 "$ssh"
fi

cp -f "$private/id_ed25519" "$ssh/id_ed25519"
cp -f "$public/id_ed25519.pub" "$ssh/id_ed25519.pub"

chown -R "tikal-root:tikal-root" "$ssh"
chmod 600 "$ssh/id_ed25519"
chmod 644 "$ssh/id_ed25519.pub"
